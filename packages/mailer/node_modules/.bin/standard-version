#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules/standard-version/bin/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules/standard-version/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules/standard-version/bin/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules/standard-version/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/standard-version@9.5.0/node_modules:/Users/juandav/Code/mailer/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../standard-version/bin/cli.js" "$@"
else
  exec node  "$basedir/../standard-version/bin/cli.js" "$@"
fi
